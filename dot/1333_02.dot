digraph timeline_1333_02 {
    # 1. 全体設定
    graph [
        charset = "UTF-8";
        layout = neato;
        overlap = false;
        sep = "+4";
        bgcolor = "#ffffff";
        splines = true;
    ];

    # 2. ノードデフォルト設定
    node [
        shape = box;
        style = "filled";
        fillcolor = "#fcfcfc";
        color = "#fcfcfc";
        penwidth = 0.1;
        fontname = "sans-serif";
        width = 1.4;
        height = 0.3;
        fixedsize = true;
    ];

    # 3. エッジデフォルト設定
    edge [
        dir = forward;
        arrowhead = normal;
        fontname = "sans-serif";
    ];

