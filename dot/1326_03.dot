digraph timeline_1326_03 {
    # 1. 全体設定
    graph [
        charset = "UTF-8";
        layout = neato;
        overlap = false;
        sep = "+4";
        bgcolor = "#ffffff";
        splines = true;
    ];

    # 2. ノードデフォルト設定
    node [
        shape = box;
        style = "filled";
        fillcolor = "#fcfcfc";
        color = "#fcfcfc";
        penwidth = 0.1;
        fontname = "sans-serif";
        width = 1.4;
        height = 0.3;
        fixedsize = true;
    ];

    # 3. エッジデフォルト設定
    edge [
        dir = forward;
        arrowhead = normal;
        fontname = "sans-serif";
    ];

    # 4. ノード定義
    # 大覚寺統・討幕過激派
    godaigo_tenno        [label="後醍醐天皇", pos="-4.82,6.44!", fontcolor="#cc0000", tooltip="大覚寺統。討幕を画策する。", URL="https://ja.wikipedia.org/wiki/後醍醐天皇", target="_blank"];
    hino_suketomo        [label="日野資朝", pos="-5.88,5.62!", fontcolor="#cc0000", tooltip="討幕計画の主要人物。", URL="https://ja.wikipedia.org/wiki/日野資朝", target="_blank"];
    hino_toshimoto       [label="日野俊基", pos="-5.41,5.94!", fontcolor="#cc0000", tooltip="討幕計画の主要人物。", URL="https://ja.wikipedia.org/wiki/日野俊基", target="_blank"];
    madenokoji_nobufusa  [label="万里小路宣房", pos="-4.12,5.21!", fontcolor="#000000", tooltip="後醍醐の側近。", URL="https://ja.wikipedia.org/wiki/万里小路宣房", target="_blank"];
    horikawa_tomochika   [label="堀川具親", pos="-5.15,4.85!", fontcolor="#000000", tooltip="公卿。", URL="https://ja.wikipedia.org/wiki/堀川具親", target="_blank"];

    # 持明院統
    gofushimi_in         [label="後伏見院", pos="-2.81,6.14!", fontcolor="#0000cc", tooltip="持明院統。幕府の支持を受ける。", URL="https://ja.wikipedia.org/wiki/後伏見天皇", target="_blank"];
    hanazono_in          [label="花園院", pos="-3.24,5.88!", fontcolor="#0000cc", tooltip="持明院統。", URL="https://ja.wikipedia.org/wiki/花園天皇", target="_blank"];
    gofukakusa_in        [label="後深草院", pos="-2.11,5.66!", fontcolor="#aaaaaa", tooltip="持明院統。", URL="https://ja.wikipedia.org/wiki/後深草天皇", target="_blank"];

    # 鎌倉幕府
    hojo_takatoki        [label="北条高時", pos="2.41,4.89!", fontcolor="#004400", tooltip="鎌倉幕府得宗。", URL="https://ja.wikipedia.org/wiki/北条高時", target="_blank"];
    hojo_sadatoki        [label="北条貞時", pos="1.98,5.12!", fontcolor="#aaaaaa", tooltip="鎌倉幕府得宗。", URL="https://ja.wikipedia.org/wiki/北条貞時", target="_blank"];
    nagasaki_takasuke    [label="長崎高資", pos="0.24,0.48!", fontcolor="#004400", tooltip="鎌倉幕府内管領。", URL="https://ja.wikipedia.org/wiki/長崎高資", target="_blank"];
    nagasaki_enki        [label="長崎円喜", pos="-0.12,0.32!", fontcolor="#004400", tooltip="鎌倉幕府内管領。", URL="https://ja.wikipedia.org/wiki/長崎円喜", target="_blank"];
    uesugi_shigefusa     [label="上杉重房", pos="5.42,5.12!", fontcolor="#444444", tooltip="有力御家人。", URL="https://ja.wikipedia.org/wiki/上杉重房", target="_blank"];

    # 武士・その他
    ando_suehisa         [label="安藤季長", pos="4.52,2.41!", fontcolor="#000000", tooltip="安藤氏の乱当事者。幕府へ上訴中。", URL="https://ja.wikipedia.org/wiki/安藤氏_(鎌倉時代)", target="_blank"];
    ando_suesada         [label="安藤季貞", pos="4.88,1.95!", fontcolor="#000000", tooltip="安藤氏の乱当事者。幕府へ上訴中。", URL="https://ja.wikipedia.org/wiki/安藤氏_(鎌倉時代)", target="_blank"];
    ashikaga_takauji     [label="足利高氏", pos="1.15,-0.85!", fontcolor="#000000", tooltip="鎌倉幕府の有力御家人。", URL="https://ja.wikipedia.org/wiki/足利尊氏", target="_blank"];
    sasaki_doyo          [label="佐々木道誉", pos="0.68,-3.62!", fontcolor="#000000", tooltip="幕府の有力御家人。", URL="https://ja.wikipedia.org/wiki/佐々木道誉", target="_blank"];
    toki_yorisada        [label="土岐頼貞", pos="2.12,1.65!", fontcolor="#444444", tooltip="有力武士。", URL="https://ja.wikipedia.org/wiki/土岐頼貞", target="_blank"];
    shimazu_sadahisa     [label="島津貞久", pos="-5.72,-5.12!", fontcolor="#444444", tooltip="有力武士。", URL="https://ja.wikipedia.org/wiki/島津貞久", target="_blank"];
    ouchi_nagahiro       [label="大内長弘", pos="-3.45,-2.12!", fontcolor="#444444", tooltip="有力武士。", URL="https://ja.wikipedia.org/wiki/大内長弘", target="_blank"];
    muso_soseki          [label="夢窓疎石", pos="6.45,-3.85!", fontcolor="#444444", tooltip="禅僧。", URL="https://ja.wikipedia.org/wiki/夢窓疎石", target="_blank"];
    monbun_kenshin       [label="聞文謙信", pos="5.82,-4.42!", fontcolor="#444444", tooltip="僧侶。", URL="https://ja.wikipedia.org/wiki/聞文謙信", target="_blank"];

    # 5. エッジ定義
    # 重要度：太（指令・統制）
    edge [penwidth=2.8, arrowsize=1.0, color="#cc0000"];
    godaigo_tenno -> hino_suketomo [tooltip="討幕計画の指令。"];
    godaigo_tenno -> hino_toshimoto [tooltip="討幕計画の指令。"];
    godaigo_tenno -> madenokoji_nobufusa [tooltip="後醍醐の側近。"];
    godaigo_tenno -> horikawa_tomochika [tooltip="宮方の公卿。"];
    
    edge [color="#005500"];
    hojo_takatoki -> nagasaki_takasuke [tooltip="幕府の支配体制。"];
    hojo_takatoki -> nagasaki_enki [tooltip="幕府の支配体制。"];
    hojo_takatoki -> uesugi_shigefusa [tooltip="鎌倉幕府の有力御家人。"];

    # 重要度：中（連帯・君臣）
    edge [penwidth=2.0, arrowsize=0.8, color="#555555"];
    hojo_sadatoki -> hojo_takatoki [tooltip="得宗家嫡流。"];
    ashikaga_takauji -> hojo_takatoki [tooltip="将軍への忠誠。"];
    sasaki_doyo -> hojo_takatoki [tooltip="幕府御家人としての関係。"];
    toki_yorisada -> hojo_takatoki [tooltip="有力武士。"];
    
    edge [color="#0000aa"];
    gofushimi_in -> hanazono_in [tooltip="持明院統の連携。"];
    gofushimi_in -> gofukakusa_in [tooltip="持明院統の先祖。"];

    # 重要度：細（一門・周辺連携）
    edge [penwidth=1.5, arrowsize=0.6, color="#666666"];
    ando_suehisa -> ando_suesada [tooltip="安藤氏一門。"];
    muso_soseki -> monbun_kenshin [tooltip="禅僧と僧侶。"];
    shimazu_sadahisa -> ouchi_nagahiro [tooltip="諸国の有力武士。"];
}