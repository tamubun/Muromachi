digraph timeline_1326_03 {
    # 1. 全体設定
    graph [
        charset = "UTF-8";
        layout = neato;
        overlap = false;
        sep = "+4";
        bgcolor = "#ffffff";
        splines = true;
    ];

    # 2. ノードデフォルト設定
    node [
        shape = box;
        style = "filled";
        fillcolor = "#fcfcfc"; 
        color = "#fcfcfc";     
        penwidth = 0.1;
        fontname = "sans-serif";
        width = 1.4;           
        height = 0.3;
        fixedsize = true;
    ];

    # 3. エッジデフォルト設定
    edge [
        dir = forward;         
        arrowhead = normal;
        fontname = "sans-serif";
        fontsize = 10;
    ];

    # ==========================================
    # 4. ノード定義 (1326_03時点の生存者)
    # ==========================================
    
    # --- 大覚寺統・討幕過激派 (fontcolor = "#cc0000") ---
    godaigo_tenno        [label="後醍醐天皇", pos="-4.82,6.44!", fontcolor="#cc0000", fontsize=16, tooltip="大覚寺統の天皇。密かに討幕を計画。", URL="https://ja.wikipedia.org/wiki/後醍醐天皇", target="_blank"];
    hino_suketomo        [label="日野資朝", pos="-5.88,5.62!", fontcolor="#cc0000", fontsize=13, tooltip="天皇の側近。無礼講を主宰し討幕を謀る。", URL="https://ja.wikipedia.org/wiki/日野資朝", target="_blank"];
    hino_toshimoto       [label="日野俊基", pos="-5.41,5.94!", fontcolor="#cc0000", fontsize=13, tooltip="天皇の側近。資朝とともに討幕運動を推進。", URL="https://ja.wikipedia.org/wiki/日野俊基", target="_blank"];
    monbun_kenshin       [label="文観", pos="5.82,-4.42!", fontcolor="#cc0000", fontsize=13, tooltip="醍醐寺の僧。真言密教を以て後醍醐を祈祷・調伏で支える。", URL="https://ja.wikipedia.org/wiki/文観", target="_blank"];

    # --- 持明院統 (fontcolor = "#0000cc") ---
    gofushimi_in         [label="後伏見院", pos="-2.81,6.14!", fontcolor="#0000cc", fontsize=14, tooltip="持明院統の院。大覚寺統の動きを警戒。", URL="https://ja.wikipedia.org/wiki/後伏見天皇", target="_blank"];
    hanazono_in          [label="花園院", pos="-3.24,5.88!", fontcolor="#0000cc", fontsize=14, tooltip="持明院統の院。政情不安を深く憂慮。", URL="https://ja.wikipedia.org/wiki/花園天皇", target="_blank"];

    # --- 鎌倉幕府中枢 (fontcolor = "#004400") ---
    hojo_takatoki        [label="北条高時", pos="2.41,4.89!", fontcolor="#004400", fontsize=15, tooltip="鎌倉幕府第14代執権。得宗。", URL="https://ja.wikipedia.org/wiki/北条高時", target="_blank"];
    nagasaki_enki        [label="長崎円喜", pos="-0.12,0.32!", fontcolor="#004400", fontsize=13, tooltip="得宗家内管領。実質的な幕政の最高権力者。", URL="https://ja.wikipedia.org/wiki/長崎円喜", target="_blank"];
    nagasaki_takasuke    [label="長崎高資", pos="0.24,0.48!", fontcolor="#004400", fontsize=13, tooltip="円喜の子。内管領として権勢を振るう。", URL="https://ja.wikipedia.org/wiki/長崎高資", target="_blank"];

    # --- 主要実務派・主要武士 (fontcolor = "#000000") ---
    madenokoji_nobufusa  [label="万里小路宣房", pos="-4.12,5.21!", fontcolor="#000000", fontsize=12, tooltip="後醍醐天皇の側近。実務派公卿。", URL="https://ja.wikipedia.org/wiki/万里小路宣房", target="_blank"];
    ashikaga_takauji     [label="足利高氏", pos="1.15,-0.85!", fontcolor="#000000", fontsize=13, tooltip="足利宗家嫡男。後の足利尊氏。動向を注視。", URL="https://ja.wikipedia.org/wiki/足利尊氏", target="_blank"];
    sasaki_doyo          [label="佐々木道誉", pos="0.68,-3.62!", fontcolor="#000000", fontsize=12, tooltip="近江の有力御家人。ばさら大名の片鱗。", URL="https://ja.wikipedia.org/wiki/佐々木道誉", target="_blank"];

    # --- 諸国武士・周辺・文化宗教 (fontcolor = "#444444") ---
    horikawa_tomochika   [label="堀川具親", pos="-5.15,4.85!", fontcolor="#444444", fontsize=12, tooltip="公卿。正中の変に関与し処分される。", URL="https://ja.wikipedia.org/wiki/堀川具親", target="_blank"];
    toki_yorisada        [label="土岐頼貞", pos="2.12,1.65!", fontcolor="#444444", fontsize=12, tooltip="美濃守護。一族が正中の変に関与。", URL="https://ja.wikipedia.org/wiki/土岐頼貞", target="_blank"];
    shimazu_sadahisa     [label="島津貞久", pos="-5.72,-5.12!", fontcolor="#444444", fontsize=11, tooltip="薩摩の有力御家人。", URL="https://ja.wikipedia.org/wiki/島津貞久", target="_blank"];
    ouchi_nagahiro       [label="大内長弘", pos="-3.45,-2.12!", fontcolor="#444444", fontsize=11, tooltip="周防の武士。", URL="https://ja.wikipedia.org/wiki/大内長弘", target="_blank"];
    muso_soseki          [label="夢窓疎石", pos="6.45,-3.85!", fontcolor="#444444", fontsize=12, tooltip="高徳の禅僧。後醍醐天皇や幕府から帰依を受ける。", URL="https://ja.wikipedia.org/wiki/夢窓疎石", target="_blank"];
    uesugi_shigefusa     [label="上杉重房", pos="5.42,5.12!", fontcolor="#444444", fontsize=11, tooltip="足利氏に仕える宿老。", URL="https://ja.wikipedia.org/wiki/上杉重房", target="_blank"];

    # ==========================================
    # 5. エッジ定義
    # ==========================================

    # 【重要度：太】中枢の支配
    nagasaki_enki -> hojo_takatoki [penwidth=4.0, arrowsize=1.4, color="#005500", tooltip="内管領として得宗高時を圧倒的に主導（後見・主導）"];

    # 【重要度：中】主従関係・対立
    hino_suketomo -> godaigo_tenno [penwidth=3.2, arrowsize=1.2, color="#ff4444", tooltip="無礼講などを通じて天皇の討幕意志に同心（討幕密議）"];
    hino_toshimoto -> godaigo_tenno [penwidth=3.2, arrowsize=1.2, color="#ff4444", tooltip="資朝とともに討幕のネットワークを画策（討幕密議）"];
    madenokoji_nobufusa -> godaigo_tenno [penwidth=3.2, arrowsize=1.2, color="#ff4444", tooltip="側近（後醍醐の「後の三房」の一人）として実務面から朝政を支える（君臣・側近）"];
    monbun_kenshin -> godaigo_tenno [penwidth=3.2, arrowsize=1.2, color="#ff4444", tooltip="真言密教による調伏・祈祷で後醍醐を精神的・謀略的に支援（討幕祈祷）"];
    nagasaki_takasuke -> nagasaki_enki [penwidth=3.2, arrowsize=1.2, color="#005500", tooltip="父子で得宗家および幕府の実権を掌握（共同幕政）"];
    gofushimi_in -> godaigo_tenno [penwidth=3.2, arrowsize=1.2, color="#0000aa", tooltip="皇位継承を巡り、大覚寺統の後醍醐天皇の動向を激しく警戒（持明院統による警戒）"];

    # 【重要度：細】間接的な関与
    godaigo_tenno -> muso_soseki [penwidth=2.5, arrowsize=1.0, color="#8844aa", tooltip="優れた禅僧として宮廷に召し出すなど深く信頼（帰依・召聘）"];
    uesugi_shigefusa -> ashikaga_takauji [penwidth=2.5, arrowsize=1.0, color="#555555", tooltip="足利宗家に仕え、一族を支える土台となる（内臣・宿老）"];
}